# Copia este archivo como .env y ajusta los valores según tu entorno.

# Django
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Base de datos PostgreSQL
POSTGRES_DB=gcs_db
POSTGRES_USER=gcs_user
POSTGRES_PASSWORD=gcs_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Para correr tests en local sin Postgres, descomenta:
# USE_SQLITE=True
